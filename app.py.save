# -----------------------------
# FUNCTIONS
# -----------------------------

def geocode_address(address):
    url = "https://nominatim.openstreetmap.org/search"
    params = {
        "q": address,
        "format": "json",
        "limit": 1
    }
    headers = {
        "User-Agent": "MRB-Airbtics-Analyzer"
    }

    response = requests.get(url, params=params, headers=headers, timeout=20)
    response.raise_for_status()
    data = response.json()

    if not data:
        return None, None

    return float(data[0]["lat"]), float(data[0]["lon"])


def make_bounds(lat, lng, radius_miles):
    lat_change = radius_miles / 69.0
    lng_change = radius_miles / (69.0 * math.cos(math.radians(lat)))

    return {
        "ne_lat": lat + lat_change,
        "ne_lng": lng + lng_change,
        "sw_lat": lat - lat_change,
        "sw_lng": lng - lng_change
    }


def normalize_airbtics_response(data):
    """
    Airbtics sometimes returns:
    1. {"message": [ {...}, {...} ]}
    2. {"message": "[{...}, {...}]"}
    3. {"message": {"listings": "[{...}, {...}]"}}
    4. {"message": {"listings": {"message": [ {...} ]}}}
    This function safely converts all common versions into a Python list of dicts.
    """

    if isinstance(data, list):
        return data

    if not isinstance(data, dict):
        return []

    message = data.get("message", data)

    if isinstance(message, list):
        return message

    if isinstance(message, str):
        try:
            parsed = json.loads(message)
            if isinstance(parsed, dict):
                return normalize_airbtics_response(parsed)
            if isinstance(parsed, list):
                return parsed
        except Exception:
            return []

    if isinstance(message, dict):
        listings = message.get("listings", message.get("data", []))

        if isinstance(listings, list):
            return listings

        if isinstance(listings, str):
            try:
                parsed = json.loads(listings)
                if isinstance(parsed, dict):
                    return normalize_airbtics_response(parsed)
                if isinstance(parsed, list):
                    return parsed
            except Exception:
                return []

        if isinstance(listings, dict):
            return normalize_airbtics_response(listings)

    return []


def safe_number(value, default=0):
    try:
        if value is None or value == "":
            return default
        return float(value)
    except Exception:
        return default


def mrb_tier(occupancy):
    if occupancy >= 80:
        return "A+"
    elif occupancy >= 70:
        return "A"
    elif occupancy >= 65:
        return "B / Pass"
    else:
        return "Fail"


