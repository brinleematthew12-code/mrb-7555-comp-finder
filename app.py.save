        col5.metric("Avg Qualified Annual Revenue", f"${qualified['Annual Revenue'].mean():,.0f}")
        col6.metric("Median Qualified Annual Revenue", f"${qualified['Annual Revenue'].median():,.0f}")
        col7.metric("Top Qualified Annual Revenue", f"${qualified['Annual Revenue'].max():,.0f}")

    st.header("Qualified 75/55 Airbnb Comps")
    if len(qualified):
        st.success(f"{len(qualified)} comps passed the MRB 75/55 rule.")
        st.dataframe(qualified, use_container_width=True)
    else:
        st.error("No comps passed the MRB 75/55 rule.")

    st.header("All Returned Comps")
    st.dataframe(df, use_container_width=True)

    st.download_button(
        "Download Qualified 75/55 Comps CSV",
        qualified.to_csv(index=False),
        "qualified_75_55_airbtics_comps.csv",
        "text/csv"
    )

    st.download_button(
        "Download All Comps CSV",
        df.to_csv(index=False),
        "all_airbtics_comps.csv",
        "text/csv"
    )

    st.caption(f"Zillow URL entered: {zillow_url}")
