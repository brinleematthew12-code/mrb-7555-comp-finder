        st.stop()

    try:
        lat, lng = geocode_address(target_address)
    except Exception as e:
        st.error("Could not geocode the address.")
        st.write(e)
        st.stop()

    if lat is None or lng is None:
        st.error("Could not find that address. Try adding city, state, and ZIP.")
        st.stop()

    bounds = make_bounds(lat, lng, radius_miles)

    st.subheader("Search Area")
    st.write(f"Search Center: {lat}, {lng}")
    st.write(bounds)

    headers = {
        "x-api-key": AIRBTICS_API_KEY,
        "Content-Type": "application/json"
    }
    AIRBTICS_PACING_ENDPOINT = ("https://crap0y5bx5.execute-api.us-east-2.amazonaws.com/prod/markets/metrics/future/pacing?market_id=462"
    )

    st.subheader("Pacing Debug")

    st.write("Pacing Endpoint:")
    st.code(AIRBTICS_PACING_ENDPOINT)

    pacing_response = requests.get(
        AIRBTICS_PACING_ENDPOINT,
        headers=headers,
        timeout=30
    )

    st.write("Pacing Status:", pacing_response.status_code)

    try:
        st.json(pacing_response.json())
    except:
        st.write(pacing_response.text)

    payload = {
        "bounds": bounds,
        "page": 1,
        "filters": {
            "property_type": ["entire_home", "private_room"],
            "bedrooms": bedroom_options,
            "bathrooms": bathroom_options,
            "sleeps": {
                "min": int(min_sleeps),
                "max": int(max_sleeps)
            },
            "minstay": {
                "min": 1
            },
            "rating": {
                "min": float(min_rating)
            },
            "reviews": min_reviews,
            "adr": {
                "min": int(min_adr),
                "max": int(max_adr)
            },
            "revenue": {
                "min": int(min_revenue)
            }
        }
    }

    try:
        response = requests.post(
            AIRBTICS_ENDPOINT,
            headers=headers,
            json=payload,
            timeout=45
        )

        st.subheader("Airbtics API Status")
        st.write(response.status_code)

        if response.status_code != 200:
            st.error("Airbtics API returned an error.")
            st.write(response.text)
            st.stop()

        data = response.json()

    except Exception as e:
        st.error("Could not connect to Airbtics.")
        st.write(e)
        st.stop()

    if show_raw_response:
        st.subheader("Raw Airbtics Response")
        st.json(data)

    comps = normalize_airbtics_response(data)

    st.write(f"Found {len(comps)} raw comps from Airbtics.")

    # TEST LIVE LISTING ENDPOINT
    if len(comps) > 0:

        first_comp = comps[0]
        listing_id = first_comp.get("listingID")

        if listing_id:

            live_url = (
                f"https://crap0y5bx5.execute-api.us-east-2.amazonaws.com/prod/live/listing/search?listing_id={listing_id}"
            )

            st.write("Testing Listing ID:", listing_id)

            live_response = requests.get(
                live_url,
                headers=headers,
                timeout=30
            )

            st.write("Live Listing Status:", live_response.status_code)

            try:
                live_data = live_response.json()

                st.write("Top Level Keys:")
                st.write(list(live_data.keys()))

                if "message" in live_data:
                    st.write("Message Keys:")
                    st.write(list(live_data["message"].keys()))

                st.json(live_data)

            except Exception as e:
                st.write(e)
                st.text(live_response.text)

    if not comps:
        st.warning("No comps found. Turn on raw response to inspect the API data.")
        st.stop()

    rows = []

    for comp in comps:
        if not isinstance(comp, dict):
            continue

        occupancy = safe_number(comp.get("avg_occupancy_rate_ltm"))
        adr = safe_number(comp.get("avg_booked_daily_rate_ltm"))
        annual_revenue = safe_number(comp.get("annual_revenue_ltm"))
        revenue_potential = safe_number(comp.get("revenue_potential"))
        active_days = safe_number(comp.get("active_days_count_ltm"))
        bookings = safe_number(comp.get("no_of_bookings_ltm"))
        cleaning_fee = safe_number(comp.get("cleaning_fee"))

        passes_75_55 = occupancy >= occupancy_threshold

        airbnb_url = ""
        listing_id = comp.get("listingID", "")
        if listing_id:
            airbnb_url = f"https://www.airbnb.com/rooms/{listing_id}"

        rows.append({
            "Passes 75/55": passes_75_55,
            "MRB Tier": mrb_tier(occupancy),
            "Listing": comp.get("name", "Unknown"),
            "Airbnb URL": airbnb_url,
            "Beds": comp.get("bedrooms", ""),
            "Baths": comp.get("bathrooms", ""),
            "Sleeps": comp.get("accommodates", ""),
            "Type": comp.get("room_and_property_type", ""),
            "ADR": adr,
            "Occupancy %": occupancy,
            "Annual Revenue": annual_revenue,
            "Revenue Potential": revenue_potential,
            "Active Days": active_days,
            "Bookings LTM": bookings,
            "Cleaning Fee": cleaning_fee,
            "Reviews": comp.get("visible_review_count", ""),
            "Rating": comp.get("reveiw_scores_rating", ""),
            "Min Nights": comp.get("minimum_nights", ""),
            "License": comp.get("license", ""),
            "Has License": comp.get("has_license", ""),
            "Host": comp.get("host_name", ""),
            "Latitude": comp.get("latitude", ""),
            "Longitude": comp.get("longitude", ""),
            "Thumbnail": comp.get("thumbnail_url", "")
        })

    df = pd.DataFrame(rows)

    if df.empty:
        st.warning("Comps returned, but none were valid listing records.")
        st.stop()

    df = df.sort_values(
        by=["Passes 75/55", "Annual Revenue", "Occupancy %"],
        ascending=[False, False, False]
    )

    qualified = df[df["Passes 75/55"] == True]
    failed = df[df["Passes 75/55"] == False]

    st.divider()
    st.header("MRB 75/55 Summary")

    col1, col2, col3, col4 = st.columns(4)

    col1.metric("Raw Comps Found", len(df))
    col2.metric("Qualified Comps", len(qualified))
    col3.metric("Average Qualified ADR", f"${qualified['ADR'].mean():,.0f}" if len(qualified) else "$0")
    col4.metric("Average Qualified Occupancy", f"{qualified['Occupancy %'].mean():.1f}%" if len(qualified) else "0%")

    if len(qualified):
